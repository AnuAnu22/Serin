# ── Required ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── LLM Backend (llama-swap or any OpenAI-compatible server) ─────────────
# Base URL for llama-swap / vLLM / OpenAI-compatible API
LLM_BASE_URL=http://localhost:8080/v1
# API key (ignored by most local backends, set for remote)
LLM_API_KEY=unused
# Default model identifier
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── LLM Generation Parameters ─────────────────────────────────────────────
LLM_TEMPERATURE=0.75
LLM_TOP_P=0.9
LLM_MAX_TOKENS=400
# Enable thinking/reasoning tokens (Gemma 4, DeepSeek R1, etc.)
LLM_ENABLE_THINKING=false

# ── Vision / Audio capabilities (set true if your LLM supports these) ─────
LLM_SUPPORTS_VISION=false
VISION_MODEL=smolvlm256m
LLM_SUPPORTS_AUDIO=false

# ── Qdrant Vector Database ────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Auto-manage Qdrant via Docker (true) or use existing instance (false)
QDRANT_USE_DOCKER=false
# Docker container name and image (only used when QDRANT_USE_DOCKER=true)
QDRANT_DOCKER_CONTAINER_NAME=serin-qdrant
QDRANT_DOCKER_IMAGE=qdrant/qdrant:latest

# ── Discord Channels ──────────────────────────────────────────────────────
# Comma-separated channel IDs where the bot may respond
# ALLOWED_CHANNEL_IDS=123456789,987654321

# ── Voice ─────────────────────────────────────────────────────────────────
ENABLE_VOICE=true
ENABLE_TTS=true
# Receiver mode: "rust" (DAVE-compatible, default) or "pycord" (AudioSink)
VOICE_RECEIVER_MODE=rust
# Path to the Rust voice receiver binary (auto-detected if not set)
# RUST_VOICE_RECEIVER_PATH=./voice_receiver

# ── Control Panel ─────────────────────────────────────────────────────────
CONTROL_PANEL_PORT=8081
# Set to enable auth; empty = no auth (dev only)
CONTROL_PANEL_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────
DEBUG_MODE=true
TRACE_MESSAGES=true
# Verbose logging for LLM input/output, memory operations, voice events
DEBUG_MEMORY=false
DEBUG_LLM=false

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
# Format: "text" (default) or "json"
LOG_FORMAT=text

# ── Maintenance ───────────────────────────────────────────────────────────
MAINTENANCE_INTERVAL_HOURS=24
