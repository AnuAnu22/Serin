# Discord (required for bot startup)
DISCORD_TOKEN=your_discord_bot_token_here

# LLM backend (OpenAI-compatible API, e.g. llama-swap, vLLM, Ollama)
VLLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=gemma12b
LLM_PROVIDER=vllm

# Alternative: direct model config
# LLM_API_URL=http://localhost:30000/v1
# LLM_MODEL=solidrust/Hermes-3-Llama-3.1-8B-AWQ

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Feature flags
ENABLE_VOICE=true
ENABLE_TTS=true
VOICE_RECEIVER_MODE=rust  # "rust" (DAVE-compatible) or "pycord" (AudioSink)
LLM_SUPPORTS_VISION=true  # Set true if model supports vision (gemma12b, smolvlm, etc.)
LLM_SUPPORTS_AUDIO=true   # Set true if model supports audio input (gemma12b)
VISION_MODEL=smolvlm256m

# Control panel (serves on this port, separate from LLM on 8080)
CONTROL_PANEL_PORT=8081
CONTROL_PANEL_KEY=your_secret_api_key_here  # Set to enable auth; empty = no auth (dev only)

# Debug logging
DEBUG_MODE=true
TRACE_MESSAGES=true

# Optional: restrict bot to specific channels (comma-separated IDs)
# ALLOWED_CHANNEL_IDS=123456789,987654321
